    {
      "name": "CreateEmployee",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "// Random Mobile Number --------------------------------------------------------------------------------\r",
              "let RandomNumber=Math.round(Math.random()*9999999);\r",
              "let prifixNum='0161';\r",
              "let MobileNumber=prifixNum+RandomNumber;\r",
              "console.log(MobileNumber)\r",
              "pm.collectionVariables.set(\"MobileNumber\", MobileNumber);\r",
              "\r",
              "\r",
              "// Radom Depertment -----------------------------------------------------------------------------------\r",
              "\r",
              "let DepertmentName=[\"Engineering\", \"Marketing\", \"Finance\", \"HR\", \"IT\"];\r",
              "let RandomDepertment=Math.floor(Math.random()*DepertmentName.length);\r",
              " let DepertmentIndex=DepertmentName[RandomDepertment];\r",
              " console.log(DepertmentIndex)\r",
              " pm.collectionVariables.set('DepertmentIndex',DepertmentIndex);"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        },
        {
          "listen": "test",
          "script": {
            "exec": [
              "// 1. Status code is 201",
              "pm.test(\"Status code is 201\", function () {",
              "    pm.response.to.have.status(201);",
              "});",
              "",
              "// 2. Response has success: true",
              "pm.test(\"Response has success: true\", function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData.success).to.be.true;",
              "});",
              "",
              "// 3. Response contains a message field equal to \"Employee created successfully\"",
              "pm.test(\"Response contains correct message\", function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData.message).to.eql(\"Employee created successfully\");",
              "});",
              "",
              "// 4. Response data contains an id (number type)",
              "pm.test(\"Response data contains an id of type number\", function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData.data).to.have.property(\"id\");",
              "    pm.expect(jsonData.data.id).to.be.a(\"number\");",
              "});",
              "",
              "// 5. Response data contains the correct fields",
              "pm.test(\"Response data contains the correct fields\", function () {",
              "    var jsonData = pm.response.json();",
              "    var data = jsonData.data;",
              "    pm.expect(data).to.have.property(\"firstName\");",
              "    pm.expect(data).to.have.property(\"lastName\");",
              "    pm.expect(data).to.have.property(\"email\");",
              "    pm.expect(data).to.have.property(\"phone\");",
              "    pm.expect(data).to.have.property(\"department\");",
              "    pm.expect(data).to.have.property(\"position\");",
              "    pm.expect(data).to.have.property(\"salary\");",
              "    pm.expect(data).to.have.property(\"hireDate\");",
              "    pm.expect(data).to.have.property(\"status\");",
              "});",
              "",
              "// 6. Response time is less than 2000ms",
              "pm.test(\"Response time is less than 2000ms\", function () {",
              "    pm.expect(pm.response.responseTime).to.be.below(2000);",
              "});",
              "",
              "// 7. Response data salary is a number",
              "pm.test(\"Response data salary is a number\", function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData.data.salary).to.be.a(\"number\");",
              "});",
              "",
              "// 8. Response data status equals \"active\"",
              "pm.test(\"Response data status equals 'active'\", function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData.data.status).to.eql(\"active\");",
              "});",
              "",
              "// 9. Response contains createdBy field",
              "pm.test(\"Response contains createdBy field\", function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData).to.have.property(\"createdBy\");",
              "});",
              "",
              "// 10. Response data createdAt and updatedAt are valid date strings",
              "pm.test(\"Response data createdAt and updatedAt are valid date strings\", function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(new Date(jsonData.data.createdAt).toString()).to.not.eql(\"Invalid Date\");",
              "    pm.expect(new Date(jsonData.data.updatedAt).toString()).to.not.eql(\"Invalid Date\");",
              "});",
              "",
              "// 11. Response Content-Type is application/json",
              "pm.test(\"Response Content-Type is application/json\", function () {",
              "    pm.expect(pm.response.headers.get(\"Content-Type\")).to.include(\"application/json\");",
              "});",
              "",
              "// 12. Response data email contains '@'",
              "pm.test(\"Response data email contains '@'\", function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData.data.email).to.include(\"@\");",
              "});",
              "",
              "// 13. Response data position is a string and not empty",
              "pm.test(\"Response data position is a string and not empty\", function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData.data.position).to.be.a(\"string\").and.to.have.length.above(0);",
              "});",
              "",
              "// 14. Response data hireDate is a valid date format (YYYY-MM-DD)",
              "pm.test(\"Response data hireDate is a valid date format (YYYY-MM-DD)\", function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData.data.hireDate).to.match(/^\\d{4}-\\d{2}-\\d{2}$/);",
              "});",
              "",
              "// 15. Response data phone is a string and not empty",
              "pm.test(\"Response data phone is a string and not empty\", function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData.data.phone).to.be.a(\"string\").and.to.have.length.above(0);",
              "});",
              "",
              "// INTENTIONAL FAIL - for demonstration purposes",
              "pm.test(\"Response data salary equals 99999 (intentional fail)\", function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData.data.salary).to.eql(99999);",
              "});",
              "",
              "// INTENTIONAL FAIL - for demonstration purposes",
              "pm.test(\"Response data id is greater than 9999 (intentional fail)\", function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData.data.id).to.be.above(9999);",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
